# Copy to .env and fill in. File .env is gitignored.

SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/cinebuzz
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=CHANGEME

SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=CHANGEME_APP_PASSWORD

R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY=CHANGEME
R2_SECRET_KEY=CHANGEME
R2_BUCKET=your-bucket
R2_PUBLIC_URL=https://your-public-r2-dev-url

JWT_SECRET=CHANGEME_BASE64_OR_HEX_KEY_LONG_ENOUGH

CINEBUZZ_MAIL_FROM=your-email@gmail.com
